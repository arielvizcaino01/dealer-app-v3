generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum VehicleStatus {
  PURCHASED
  IN_TRANSIT
  IN_REPAIR
  READY_FOR_SALE
  SOLD
}

enum ExpenseCategory {
  TRANSPORT
  PARTS
  LABOR
  TAXES
  REPAIR
  OTHER
}

model Vehicle {
  id                 String         @id @default(cuid())
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  source             String         @default("COPART")
  lotNumber          String         @unique
  vin                String         @unique
  year               Int
  make               String
  model              String
  miles              Int?
  primaryDamage      String?
  secondaryDamage    String?
  titleStatus        String?
  fuelType           String?
  engine             String?
  purchasePrice      Float          @default(0)
  estimatedSalePrice Float          @default(0)
  actualSalePrice    Float?
  status             VehicleStatus  @default(PURCHASED)
  notes              String?
  thumbnailUrl       String?
  photos             VehiclePhoto[]
  expenses           Expense[]
}

model VehiclePhoto {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  url       String
  label     String?
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  description String
  amount      Float
  category    ExpenseCategory
  vehicleId   String
  vehicle     Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model BusinessSettings {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  initialCapital Float    @default(0)
}